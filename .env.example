# Obrigatoria para o chatbot funcionar
OPENAI_API_KEY=

# Opcional: modelo e temperatura do LLM
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3

# Opcional: observabilidade via Langsmith (sem LANGCHAIN_API_KEY o tracing fica inerte)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=chatbot-ia

# Ambiente de execucao
APP_ENV=dev
